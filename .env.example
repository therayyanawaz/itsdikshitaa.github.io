# Environment Variables Example
# Do not commit the actual .env file with real secrets!

# Site URL for metadata/SEO
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------------------------
# Contact Form Configuration
# -------------------------------------------------------------

# Option 1: SendGrid (Recommended for control)
# Get this key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# Contact Email (where you want to receive the messages)
CONTACT_EMAIL=you@example.com

# Option 2: Formspree (Alternative if you don't want a backend server sending emails)
# Set your formspree endpoint URL. If this is set, SendGrid will be bypassed.
FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_endpoint

# Option 3: Local Dev Only
# If neither is set, contact backend will just log the message to standard output.
